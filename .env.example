# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Gmail address you want to send FROM (e.g. your own Gmail)
EMAIL_USER=you@gmail.com

# Gmail App Password (16-character code — NOT your regular Gmail password)
# How to generate one:
#   1. Enable 2-Step Verification: myaccount.google.com/security
#   2. Go to: myaccount.google.com/apppasswords
#   3. Create an app password named "MQDH Website"
#   4. Paste the 16-character code here (no spaces)
EMAIL_PASS=your_app_password_here

# Port the server listens on (default: 3000)
PORT=3000
